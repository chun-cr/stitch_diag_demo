root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.dart]
indent_size = 2

[*.py]
indent_size = 4

[*.{yaml,yml,json,arb}]
indent_size = 2

[*.ps1]
indent_size = 2
